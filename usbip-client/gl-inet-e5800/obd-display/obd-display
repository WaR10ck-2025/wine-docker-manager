#!/bin/sh /etc/rc.common
# ─────────────────────────────────────────────────────────────────────────────
# OBD2 Display — OpenWrt procd Service
# GL.iNet GL-E5800 (Mudi 7)
#
# Startet NACH obd-monitor (START=96 > 95).
# Pillow wird aus dem venv gestartet (/opt/obd-venv).
#
# Installation:
#   cp obd-display /etc/init.d/obd-display
#   chmod +x /etc/init.d/obd-display
#   /etc/init.d/obd-display enable
#   /etc/init.d/obd-display start
#
# Logs: logread | grep -i 'obd-display\|[display]'
# ─────────────────────────────────────────────────────────────────────────────

USE_PROCD=1
START=96
STOP=9

VENV_DIR="/opt/obd-venv"
INSTALL_DIR="/opt/obd-monitor"

start_service() {
    if [ ! -f "$VENV_DIR/bin/python3" ]; then
        logger -t obd-display "FEHLER: $VENV_DIR nicht gefunden"
        return 1
    fi

    procd_open_instance
    procd_set_param command "$VENV_DIR/bin/python3" display_service.py
    procd_set_param dir "$INSTALL_DIR"
    procd_set_param respawn 3600 5 3
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    logger -t obd-display "Display Service gestoppt"
    # gl_screen wiederherstellen (falls vorhanden)
    if [ -f /etc/init.d/gl_screen ]; then
        /etc/init.d/gl_screen start 2>/dev/null || true
    fi
}
