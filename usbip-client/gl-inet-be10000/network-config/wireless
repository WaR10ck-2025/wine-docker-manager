# TODO: verify on hardware — radio-Pfad und Band-Konfiguration prüfen
config wifi-device 'radio0'
	option type 'mac80211'
	option path 'platform/soc/c000000.wifi'
	option channel '6'
	option band '2g'
	option htmode 'HT20'

config wifi-iface 'default_radio0'
	option device 'radio0'
	option network 'lan'
	option mode 'ap'
	option ssid 'GL-BE10000-AP'
	option encryption 'psk2'
	option key 'goodlife'

# WiFi-Client-Interface (STA-Modus — Uplink zum Heimnetz)
config wifi-iface 'wifinet_sta'
	option device 'radio0'
	option network 'wwan'
	option mode 'sta'
	option ssid 'HTP-1-2.4G'
	option encryption 'psk2'
	option key 'YOUR_WIFI_PASSWORD'
	option disabled '0'
