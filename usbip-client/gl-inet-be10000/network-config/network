config interface 'loopback'
	option device 'lo'
	option proto 'static'
	option ipaddr '127.0.0.1'
	option netmask '255.0.0.0'

config globals 'globals'
	option ula_prefix 'fde7:b4c3:a9d3::/48'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ipaddr '192.168.10.191'
	option netmask '255.255.255.0'
	option gateway '192.168.10.1'
	option dns '192.168.10.1 8.8.8.8'

# WiFi-Client (wwan) — Uplink über 2.4 GHz AP (HTP-1-2.4G)
# TODO: verify on hardware — WiFi-Interface-Name prüfen (wlan0 oder wlan1?)
config interface 'wwan'
	option proto 'static'
	option ipaddr '192.168.10.196'
	option netmask '255.255.255.0'
	option gateway '192.168.10.1'
	option dns '192.168.10.1 8.8.8.8'

config interface 'wan'
	option device 'eth0'
	option proto 'dhcp'
