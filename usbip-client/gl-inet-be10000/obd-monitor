#!/bin/sh /etc/rc.common
# ─────────────────────────────────────────────────────────────────────────────
# OBD2 Monitor — OpenWrt procd Service
# GL.iNet GL-BE10000 (Slate 7 Pro) — PROTOTYPE
#
# Verwendet venv unter /opt/obd-venv (eMMC — kein USB-Stick)
# Identisch zu GL-E5800 — TODO: verify on hardware
#
# Installation:
#   cp obd-monitor /etc/init.d/obd-monitor
#   chmod +x /etc/init.d/obd-monitor
#   /etc/init.d/obd-monitor enable
#   /etc/init.d/obd-monitor start
#
# Logs: logread | grep -i obd
# ─────────────────────────────────────────────────────────────────────────────

USE_PROCD=1
START=95
STOP=10

VENV_DIR="/opt/obd-venv"
INSTALL_DIR="/opt/obd-monitor"

start_service() {
    if [ ! -f "$VENV_DIR/bin/uvicorn" ]; then
        logger -t obd-monitor "FEHLER: $VENV_DIR/bin/uvicorn nicht gefunden — install_obd_openwrt.sh ausführen"
        return 1
    fi

    procd_open_instance
    procd_set_param command "$VENV_DIR/bin/uvicorn" obd_service:app \
        --host 0.0.0.0 \
        --port 8765 \
        --workers 1 \
        --log-level warning
    procd_set_param dir "$INSTALL_DIR"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    logger -t obd-monitor "Service gestoppt"
}
