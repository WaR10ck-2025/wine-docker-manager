# Optionale Überschreibungen
WINE_CONTAINER=wine-desktop
WINEARCH=win64
UPLOAD_DIR=/uploads

# ── QR-Code Credentials (optional) ─────────────────────────
QR_ENABLED=false                   # Auf true setzen um QR-Codes beim Deployment anzuzeigen
QR_PIN=                            # PIN fuer verschluesselte QR-Codes (z.B. 1234)

